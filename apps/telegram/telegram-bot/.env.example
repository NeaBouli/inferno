# === IFR TELEGRAM BOT — .env.example ===
# Kopiere diese Datei zu .env und befülle mit echten Werten
# .env ist in .gitignore — NIEMALS committen!

# Telegram
BOT_TOKEN=                          # Von @BotFather → /newbot

# Anthropic Claude
CLAUDE_API_KEY=                     # Bereits in Railway vorhanden — Projektleiter anfragen
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Ethereum RPC
ALCHEMY_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/<YOUR_KEY>

# IFR Contracts (Mainnet)
IFR_TOKEN_ADDRESS=0x77e99917Eca8539c62F509ED1193ac36580A6e7B
IFR_LOCK_ADDRESS=                   # Aus /docs/DEPLOYMENTS.md

# Railway Proxy (für /burns — bevorzugte Quelle)
RAILWAY_API_URL=https://ifr-ai-copilot-production.up.railway.app

# Telegram Group / Channel
TELEGRAM_GROUP_ID=-1003833113414
TELEGRAM_CHANNEL_ID=@IFRtoken
TELEGRAM_ANNOUNCEMENTS_TOPIC_ID=1
TELEGRAM_GENERAL_TOPIC_ID=5
TELEGRAM_BURNS_TOPIC_ID=7
TELEGRAM_DEV_BUILDER_TOPIC_ID=11
TELEGRAM_VOTE_TOPIC_ID=23
TELEGRAM_COUNCIL_TOPIC_ID=21
TELEGRAM_COREDEV_TOPIC_ID=58

# Admin (Telegram User IDs, kommasepariert)
ADMIN_USER_IDS=                     # Telegram User ID des Projektleiters anfragen

# Etherscan (optional — Fallback für /burns)
ETHERSCAN_API_KEY=                  # Aus Projektleiter anfragen

# Rate Limiting
RATE_LIMIT_PER_MIN=5
ASK_LIMIT_PER_HOUR=3
ASK_GLOBAL_PER_HOUR=50

# Cache TTL (Sekunden)
CACHE_TTL_SECONDS=60
CACHE_TTL_BURNS=300

# Wallet Verification (3-Tier System)
VERIFY_PORT=3006                    # Express API für verify.html
GNOSIS_SAFE_ADDR=0x5ad6193eD6E1e31ed10977E73e3B609AcBfEcE3b  # Treasury Safe → getOwners() auto-sync
SIGNER_WALLETS=                     # Fallback falls Safe nicht erreichbar (kommasepariert)
BUILDER_WALLETS=                    # Phase 1 Placeholder (kommasepariert)
BUILDER_REGISTRY_ADDR=              # Leer bis Phase 3 Contract deployed

# Environment
NODE_ENV=production
