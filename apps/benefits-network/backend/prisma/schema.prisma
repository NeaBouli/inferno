generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Business {
  id              String    @id @default(cuid())
  name            String
  description     String?
  website         String?
  serviceArea     String?
  serviceAreaKey  String?
  categoriesJson  String    @default("[]")
  ownerAddress    String?
  discountPercent Int
  requiredLockIFR Int
  ttlSeconds      Int       @default(60)
  tierLabel       String?
  active          Boolean   @default(true)
  createdAt       DateTime  @default(now())
  sessions        Session[]
  benefitRules    BenefitRule[]
  checkoutOperators CheckoutOperator[]
  products        Product[]
  rewardLink      SellerRewardLink?
  rewardEvents    RewardEvent[]

  @@index([ownerAddress])
  @@index([active, serviceAreaKey])
}

model Product {
  id          String        @id @default(cuid())
  businessId  String
  business    Business      @relation(fields: [businessId], references: [id])
  name        String
  category    String
  description String?
  active      Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  benefitRules BenefitRule[]

  @@index([businessId, active])
  @@index([category])
}

model CheckoutOperator {
  id            String    @id @default(cuid())
  businessId    String
  business      Business  @relation(fields: [businessId], references: [id])
  walletAddress String
  label         String?
  active        Boolean   @default(true)
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([businessId, walletAddress])
  @@index([businessId, active])
  @@index([walletAddress])
}

model BenefitRule {
  id              String   @id @default(cuid())
  businessId      String
  business        Business @relation(fields: [businessId], references: [id])
  productId       String?
  product         Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  label           String
  category        String
  productName     String
  discountPercent Int
  requiredLockIFR Int
  dailyRedemptionLimit Int @default(0)
  monthlyRedemptionLimit Int @default(0)
  ttlSeconds      Int      @default(90)
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  sessions        Session[]

  @@index([businessId])
  @@index([productId])
  @@index([active])
}

model Session {
  id               String     @id @default(cuid())
  businessId       String
  business         Business   @relation(fields: [businessId], references: [id])
  benefitRuleId    String?
  benefitRule      BenefitRule? @relation(fields: [benefitRuleId], references: [id])
  benefitSnapshotVersion Int?
  benefitLabel     String?
  benefitCategory  String?
  benefitProductName String?
  benefitDiscountPercent Int?
  benefitRequiredLockIFR Int?
  benefitTtlSeconds Int?
  benefitDailyRedemptionLimit Int?
  benefitMonthlyRedemptionLimit Int?
  nonce            String     @unique
  expiresAt        DateTime
  status           String     @default("PENDING")
  recoveredAddress String?
  lockAmountRaw    String?
  reason           String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  redeemedAt       DateTime?
  attestAttempts   Int        @default(0)
  customerPassId   String?    @unique
  customerPass     CustomerPass? @relation(fields: [customerPassId], references: [id])
  auditLogs        AuditLog[]
  rewardEvent      RewardEvent?

  @@index([businessId])
  @@index([benefitRuleId])
  @@index([benefitRuleId, status, redeemedAt], map: "Session_redemptionLimitLookup_idx")
  @@index([recoveredAddress, createdAt, id], map: "Session_customerHistory_idx")
  @@index([status])
}

model CustomerPass {
  id            String   @id
  walletAddress String
  controlHash   String   @unique
  status        String   @default("OPEN")
  expiresAt     DateTime
  boundAt       DateTime?
  cancelledAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  session       Session?

  @@index([status, expiresAt])
  @@index([walletAddress, createdAt])
}

model CustomerPassChallenge {
  nonce         String   @id
  walletAddress String
  issuedAt      DateTime
  expiresAt     DateTime
  consumedAt    DateTime?
  createdAt     DateTime @default(now())

  @@index([expiresAt])
  @@index([walletAddress, consumedAt])
}

model SellerRewardLink {
  id                String   @id @default(cuid())
  businessId        String   @unique
  business          Business @relation(fields: [businessId], references: [id])
  status            String   @default("APPLIED")
  partnerId         String?  @unique
  builderWallet     String?
  requestedAt       DateTime @default(now())
  verifiedAt        DateTime?
  lastCheckedAt     DateTime?
  verificationBlock String?
  governanceReference String?
  reason            String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model RewardEvent {
  id               String   @id @default(cuid())
  businessId       String
  business         Business @relation(fields: [businessId], references: [id])
  sessionId        String   @unique
  session          Session  @relation(fields: [sessionId], references: [id])
  partnerId        String
  customerWallet   String
  lockAmountRaw    String
  chainId          Int
  status           String   @default("PENDING")
  reason           String?
  txHash           String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([customerWallet, partnerId])
  @@index([businessId, status])
  @@index([partnerId])
}

model AuditLog {
  id        String   @id @default(cuid())
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id])
  type      String
  payload   String
  ts        DateTime @default(now())

  @@index([sessionId])
}

model SellerAuthorizationChallenge {
  nonce         String   @id
  walletAddress String
  action        String
  businessId    String
  scope         String
  expiresAt     DateTime
  consumedAt    DateTime?
  createdAt     DateTime @default(now())

  @@index([expiresAt])
  @@index([walletAddress, action, businessId])
}

model CustomerHistoryChallenge {
  nonce         String   @id
  walletAddress String
  issuedAt      DateTime
  expiresAt     DateTime
  consumedAt    DateTime?
  createdAt     DateTime @default(now())

  @@index([expiresAt])
  @@index([walletAddress, consumedAt])
}

model CustomerHistoryAccess {
  tokenHash     String   @id
  walletAddress String
  expiresAt     DateTime
  createdAt     DateTime @default(now())

  @@index([expiresAt])
  @@index([walletAddress, expiresAt])
}
