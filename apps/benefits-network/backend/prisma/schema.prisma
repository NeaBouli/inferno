generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Business {
  id              String    @id @default(cuid())
  name            String
  ownerAddress    String?
  discountPercent Int
  requiredLockIFR Int
  ttlSeconds      Int       @default(60)
  tierLabel       String?
  active          Boolean   @default(true)
  createdAt       DateTime  @default(now())
  sessions        Session[]
  benefitRules    BenefitRule[]
  checkoutOperators CheckoutOperator[]
  products        Product[]

  @@index([ownerAddress])
}

model Product {
  id          String        @id @default(cuid())
  businessId  String
  business    Business      @relation(fields: [businessId], references: [id])
  name        String
  category    String
  description String?
  active      Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  benefitRules BenefitRule[]

  @@index([businessId, active])
  @@index([category])
}

model CheckoutOperator {
  id            String    @id @default(cuid())
  businessId    String
  business      Business  @relation(fields: [businessId], references: [id])
  walletAddress String
  label         String?
  active        Boolean   @default(true)
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([businessId, walletAddress])
  @@index([businessId, active])
  @@index([walletAddress])
}

model BenefitRule {
  id              String   @id @default(cuid())
  businessId      String
  business        Business @relation(fields: [businessId], references: [id])
  productId       String?
  product         Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  label           String
  category        String
  productName     String
  discountPercent Int
  requiredLockIFR Int
  ttlSeconds      Int      @default(90)
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  sessions        Session[]

  @@index([businessId])
  @@index([productId])
  @@index([active])
}

model Session {
  id               String     @id @default(cuid())
  businessId       String
  business         Business   @relation(fields: [businessId], references: [id])
  benefitRuleId    String?
  benefitRule      BenefitRule? @relation(fields: [benefitRuleId], references: [id])
  benefitSnapshotVersion Int?
  benefitLabel     String?
  benefitCategory  String?
  benefitProductName String?
  benefitDiscountPercent Int?
  benefitRequiredLockIFR Int?
  benefitTtlSeconds Int?
  nonce            String     @unique
  expiresAt        DateTime
  status           String     @default("PENDING")
  recoveredAddress String?
  lockAmountRaw    String?
  reason           String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  redeemedAt       DateTime?
  attestAttempts   Int        @default(0)
  auditLogs        AuditLog[]

  @@index([businessId])
  @@index([benefitRuleId])
  @@index([status])
}

model AuditLog {
  id        String   @id @default(cuid())
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id])
  type      String
  payload   String
  ts        DateTime @default(now())

  @@index([sessionId])
}
