# X / Twitter API posting env for scripts/post-x.js
# Copy values into your local .env or server secret store. Never commit real secrets.

# Default is dry-run. Live posting requires both:
X_DRY_RUN=true
X_ALLOW_LIVE=false

# OAuth2 user-context access token for the official @IFRtoken account.
# Required for live posting unless refresh credentials are configured.
X_ACCESS_TOKEN=

# Optional OAuth2 refresh flow. Use when the X app issues refresh tokens.
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REFRESH_TOKEN=

# Optional: start a new post/thread as a reply to an existing post ID.
X_REPLY_TO_ID=
